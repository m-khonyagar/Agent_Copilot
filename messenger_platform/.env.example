# ── Telegram ───────────────────────────────────────────────────────────────────
# Required for account checking and sending messages via a real user account
TELEGRAM_API_ID=           # Get from https://my.telegram.org/apps
TELEGRAM_API_HASH=         # Get from https://my.telegram.org/apps

# Optional: Telegram Bot API (for bot-based sending)
TELEGRAM_BOT_TOKEN=        # Get from @BotFather

# ── Eitaa ──────────────────────────────────────────────────────────────────────
EITAA_TOKEN=               # Get from @EitaaBot

# ── Bale ───────────────────────────────────────────────────────────────────────
BALE_TOKEN=                # Get from @BotFather on Bale

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Admin credentials ──────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Rate limits (messages per 24 hours per platform) ──────────────────────────
TELEGRAM_DAILY_LIMIT=50
EITAA_DAILY_LIMIT=200
BALE_DAILY_LIMIT=100
RUBIKA_DAILY_LIMIT=100
WHATSAPP_DAILY_LIMIT=50
